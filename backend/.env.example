# ========================================
# Environment Variables - COPY TO .env
# ========================================

# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ipb_fasilitas

# JWT Secret Key (ganti dengan string random yang panjang)
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Algorithm
ALGORITHM=HS256

# Token expiry (dalam menit)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Upload folder (relatif dari backend/)
UPLOAD_DIR=uploads

# Cloudinary (untuk upload gambar)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS - Allowed Origins (koma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
